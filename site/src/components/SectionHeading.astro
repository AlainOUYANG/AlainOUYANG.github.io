---
type Props = {
  number: string;
  title: string;
  description?: string;
};

const { number, title, description } = Astro.props;
---

<header class="section-heading" data-section-heading>
  <span>{number}</span>
  <div>
    <h2>{title}</h2>
    {description && <p>{description}</p>}
  </div>
</header>

<style>
  .section-heading { display: grid; grid-template-columns: 3.25rem minmax(0, 1fr); gap: 1rem; margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  span { padding-top: 0.5rem; color: var(--color-accent-soft); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.16em; }
  span::after { display: block; width: 1.75rem; height: 1px; margin-top: 0.65rem; content: ''; background: currentColor; }
  h2 { max-width: 18ch; margin-bottom: 0; font-size: clamp(2rem, 5vw, 3.75rem); }
  p { max-width: 38rem; margin: 1rem 0 0; color: var(--color-muted); }
  @media (max-width: 36rem) { .section-heading { grid-template-columns: 1fr; } span { padding-top: 0; } }
</style>
