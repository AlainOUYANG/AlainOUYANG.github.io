---
type Props = {
  number: string;
  title: string;
  description?: string;
};

const { title, description } = Astro.props;
---

<header class="section-heading" data-section-heading data-editorial-header>
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</header>

<style>
  .section-heading { display: grid; grid-template-columns: minmax(0, 0.75fr) minmax(18rem, 1fr); gap: clamp(1rem, 5vw, 4rem); align-items: start; margin-bottom: clamp(1.75rem, 4vw, 2.75rem); }
  h2 { max-width: 18ch; margin: 0; font-size: clamp(1.65rem, 3.5vw, 2.25rem); }
  p { max-width: 38rem; margin: 0; color: var(--color-muted); }
  @media (max-width: 42rem) { .section-heading { grid-template-columns: 1fr; gap: 0.75rem; } }
</style>
