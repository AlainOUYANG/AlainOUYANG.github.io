---
type Props = {
  eyebrow?: string;
  title: string;
  description: string;
  href: string;
  meta?: string;
  span?: 'wide' | 'medium' | 'small';
};
const { eyebrow = 'Writing', title, description, href, meta, span = 'medium' } = Astro.props;
---

<article class:list={['article-card', 'surface-card', `article-card--${span}`]}>
  <p class="article-card__eyebrow">{eyebrow}</p>
  <h3><a href={href}>{title}</a></h3>
  <p class="article-card__description">{description}</p>
  <div class="article-card__footer"><span>{meta}</span><a href={href}>阅读<span class="visually-hidden">：{title}</span> <b aria-hidden="true">↗</b></a></div>
</article>

<style>
  .article-card { display: flex; min-height: 20rem; flex-direction: column; grid-column: span 5; }
  .article-card--wide { min-height: 25rem; grid-column: span 7; }
  .article-card--small { grid-column: span 4; }
  .article-card__eyebrow { margin-bottom: auto; color: var(--color-accent-soft); font-size: 0.68rem; font-weight: 800; letter-spacing: 0.17em; text-transform: uppercase; }
  h3 { max-width: 18ch; margin: 3rem 0 1rem; font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 3.2rem); font-weight: 500; }
  h3 a { text-decoration: none; }
  .article-card__description { max-width: 35rem; color: var(--color-muted); }
  .article-card__footer { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-top: 2rem; padding-top: 1rem; color: var(--color-subtle); font-size: 0.74rem; border-top: 1px solid var(--color-border); }
  .article-card__footer a { color: var(--color-text); font-weight: 700; text-decoration: none; }
  .article-card__footer b { color: var(--color-accent); }
  @media (max-width: 48rem) { .article-card, .article-card--wide, .article-card--small { min-height: 20rem; grid-column: 1; } }
</style>
