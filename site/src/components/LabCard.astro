---
import type { LabProject } from '../data/lab';

type Props = { project: LabProject; index: number };
const { project } = Astro.props;
---

<article class="lab-row" data-editorial-row>
  <div class="lab-row__meta"><span>Build</span><span>{project.status}</span></div>
  <div class="lab-row__content">
    <h3>{project.title}</h3>
    <p>{project.description}</p>
  </div>
  <ul class="tag-list">{project.tags.map((tag) => <li>{tag}</li>)}</ul>
</article>

<style>
  .lab-row { display: grid; grid-template-columns: 8rem minmax(0, 1fr) minmax(8rem, auto); gap: clamp(1rem, 4vw, 2.5rem); padding-block: 1.35rem; border-top: 1px solid var(--color-border); }
  .lab-row:last-child { border-bottom: 1px solid var(--color-border); }
  .lab-row__meta { display: grid; align-content: start; gap: 0.25rem; color: var(--color-subtle); font-family: var(--font-latin); font-size: 0.69rem; }
  .lab-row__meta span:last-child { color: var(--color-accent); }
  h3 { margin: 0 0 0.3rem; font-size: clamp(1.2rem, 2vw, 1.48rem); }
  .lab-row__content p { max-width: 38rem; margin: 0; color: var(--color-muted); font-size: 0.92rem; }
  .tag-list { align-content: start; justify-content: flex-end; }
  @media (max-width: 46rem) {
    .lab-row { grid-template-columns: 1fr; gap: 0.7rem; }
    .lab-row__meta { display: flex; gap: 1rem; }
    .tag-list { justify-content: flex-start; }
  }
</style>
