---
type Props = {
  eyebrow: string;
  title: string;
  description: string;
};

const { eyebrow, title, description } = Astro.props;
---

<header class="page-intro shell" data-page-intro>
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="page-intro__description">{description}</p>
</header>

<style>
  .page-intro { padding-top: clamp(4.5rem, 10vw, 7.5rem); padding-bottom: clamp(3rem, 6vw, 4.5rem); border-bottom: 1px solid var(--color-border); }
  h1 { max-width: 18ch; margin-bottom: 1.2rem; font-size: clamp(2.6rem, 6vw, 4rem); }
  .page-intro__description { max-width: 40rem; margin: 0; color: var(--color-muted); font-size: clamp(1rem, 1.5vw, 1.16rem); }
  @media (max-width: 44rem) { h1 { font-size: clamp(2.35rem, 12vw, 3.5rem); } }
</style>
