---
import { profile } from '../data/profile';
---

<footer class="site-footer" data-site-footer>
  <div class="site-footer__inner shell">
    <div>
      <p class="site-footer__statement">{profile.statement}</p>
      <p class="site-footer__meta">© {new Date().getFullYear()} Kzyo</p>
    </div>
    <nav aria-label="页脚导航">
      <a href="/archive/">归档</a>
      <a href="/rss.xml">RSS</a>
      <a href={profile.links.github} rel="me">GitHub</a>
      <a href={profile.links.scholar} rel="me">Scholar</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer { padding-block: 2.75rem; border-top: 1px solid var(--color-border); }
  .site-footer__inner { display: flex; align-items: end; justify-content: space-between; gap: 2rem; }
  .site-footer__statement { max-width: 30rem; margin-bottom: 0.4rem; font-size: 1rem; }
  .site-footer__meta { margin: 0; color: var(--color-subtle); font-family: var(--font-latin); font-size: 0.74rem; }
  nav { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 0.5rem 1.1rem; }
  nav a { color: var(--color-muted); font-family: var(--font-latin); font-size: 0.76rem; text-decoration: none; }
  @media (max-width: 42rem) {
    .site-footer__inner { align-items: start; flex-direction: column; }
    nav { justify-content: flex-start; }
  }
</style>
