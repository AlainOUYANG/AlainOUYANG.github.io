---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { publications, researchFiles } from '../../data/publications';

const scholarlyJsonLd = publications.map((publication) => ({
  '@context': 'https://schema.org', '@type': 'ScholarlyArticle', headline: publication.title,
  author: publication.authors.split(', ').map((name) => ({ '@type': 'Person', name })),
  datePublished: publication.year, isPartOf: publication.venue, sameAs: publication.doi
}));
---

<BaseLayout title="研究" description="Kzyo 的公开论文、博士研究与学术资料。" jsonLd={scholarlyJsonLd}>
  <PageIntro eyebrow="Research / 研究" title="研究训练，是判断模型边界的方法" description="从时间序列预测到室内定位，博士阶段的研究让我持续关注：问题是否被正确表述，比较是否公平，结论是否经得住验证。" />
  <section class="section-shell">
    <SectionHeading number="01" title="公开论文" description="只保留可核验的真实论文，并按规范 bibliographic record 展示作者。" />
    <div class="publication-list">
      {publications.map((publication) => <article><span>{publication.year}</span><div><h3>{publication.title}</h3><p>{publication.authors}</p><small>{publication.venue}</small></div><nav><a href={publication.doi}>DOI ↗</a>{publication.pdf && <a href={publication.pdf}>PDF ↓</a>}</nav></article>)}
    </div>
  </section>
  <section class="section-shell">
    <SectionHeading number="02" title="研究档案" />
    <div class="file-list">
      <a href={researchFiles.thesis}><span>PDF · Thesis</span><b>博士论文</b><small>完整论文文件，保留既有公开访问路径。</small></a>
      <a href={researchFiles.cv}><span>PDF · CV</span><b>英文 CV</b><small>学术经历与研究成果的英文版本。</small></a>
    </div>
  </section>
</BaseLayout>

<style>
  .publication-list, .file-list { border-top: 1px solid var(--color-border); }
  .publication-list article { display: grid; grid-template-columns: 5rem minmax(0,1fr) auto; gap: clamp(1rem,4vw,2.5rem); padding-block: 1.5rem; border-bottom: 1px solid var(--color-border); }
  .publication-list article > span { color: var(--color-subtle); font-family: var(--font-latin); font-size: .72rem; }
  .publication-list h3 { max-width: 46rem; margin: 0 0 .5rem; font-size: clamp(1.15rem,2vw,1.45rem); }
  .publication-list p, .publication-list small { display: block; margin: 0; color: var(--color-muted); font-family: var(--font-latin); font-size: .8rem; }
  .publication-list nav { display: flex; flex-direction: column; gap: .35rem; align-items: flex-end; }
  .publication-list a { font-family: var(--font-latin); font-size: .72rem; text-decoration: none; }
  .file-list a { display: grid; grid-template-columns: 8rem minmax(10rem,.6fr) minmax(16rem,1fr); gap: 2rem; padding-block: 1.25rem; text-decoration: none; border-bottom: 1px solid var(--color-border); }
  .file-list span, .file-list small { color: var(--color-subtle); }
  .file-list span { font-family: var(--font-latin); font-size: .7rem; }
  .file-list b { font-weight: 400; }
  @media (max-width: 44rem) { .publication-list article { grid-template-columns: 3rem 1fr; } .publication-list nav { grid-column: 2; flex-direction: row; align-items: flex-start; } .file-list a { grid-template-columns: 1fr; gap: .3rem; } }
</style>
