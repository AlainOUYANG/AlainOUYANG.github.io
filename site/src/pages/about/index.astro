---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { profile } from '../../data/profile';
---

<BaseLayout title="关于" description="关于佐坤：智能营销、因果推断、Uplift Modeling 与 AI 应用。">
  <PageIntro eyebrow="About / 关于" title="你好，我是佐坤" description="一名互联网营销算法工程师，也是持续做公开实验的创造者。我关心怎样识别真正的增量，也关心 AI 怎样帮助人更好地学习、表达和工作。" />

  <section class="section-shell about-profile">
    <SectionHeading number="01" title="两条工作线，一套问题意识" />
    <div class="about-profile__grid">
      <div class="about-profile__monogram" aria-hidden="true"><span>佐</span><i></i></div>
      <div class="about-profile__copy">
        <p>我的主线工作围绕智能营销、因果推断和 Uplift Modeling：从“谁可能响应”继续追问“谁会因为干预而改变”，再把答案放回实验和决策中验证。</p>
        <p>另一条线是 AI 应用与个人效率。我在探索 AI 播客、自媒体内容生成、知识管理和工作流自动化，也会用 AI 编程快速做工具和产品原型。</p>
        <p>计算机科学博士阶段的研究训练，让我习惯检查比较是否公平、指标是否回答了真正的问题，以及结论的边界在哪里。</p>
      </div>
    </div>
  </section>

  <section class="section-shell about-now">
    <SectionHeading number="02" title="现在关注" />
    <div class="about-now__list">
      <article><span>Work</span><h3>增量价值与营销决策</h3><p>异质性处理效应、实验评估和从模型到策略的连接。</p></article>
      <article><span>Build</span><h3>AI 原生工作流</h3><p>内容生产、知识管理、自动化与个人效率工具。</p></article>
      <article><span>Write</span><h3>把判断写清楚</h3><p>围绕方法、实践和阅读，留下可以复用与讨论的公开材料。</p></article>
    </div>
  </section>

  <section class="about-connect shell">
    <div><span>Connect</span><h2>在公开的地方找到我</h2></div>
    <nav aria-label="个人链接">
      <a href={profile.links.github}>GitHub ↗</a>
      <a href={profile.links.scholar}>Google Scholar ↗</a>
      <a href={profile.links.linkedin}>LinkedIn ↗</a>
      <a href={profile.links.orcid}>ORCID ↗</a>
    </nav>
  </section>
</BaseLayout>

<style>
  .about-profile__grid { display: grid; grid-template-columns: minmax(15rem, 0.8fr) minmax(0, 1.4fr); gap: clamp(2.5rem, 8vw, 7rem); align-items: center; }
  .about-profile__monogram { position: relative; display: grid; aspect-ratio: 4 / 5; place-items: center; overflow: hidden; background: radial-gradient(circle at 70% 20%, rgba(240, 138, 130, 0.5), transparent 32%), linear-gradient(145deg, var(--color-surface-raised), var(--color-bg-deep)); border: 1px solid var(--color-border); border-radius: var(--radius-card); }
  .about-profile__monogram span { z-index: 1; font-family: var(--font-display); font-size: clamp(7rem, 18vw, 13rem); line-height: 1; background: var(--gradient-accent); background-clip: text; -webkit-background-clip: text; color: transparent; }
  .about-profile__monogram i { position: absolute; inset: 10%; border: 1px solid var(--color-border); border-radius: 50%; transform: rotate(-18deg); }
  .about-profile__copy { max-width: 42rem; }
  .about-profile__copy p { color: var(--color-muted); font-size: clamp(1.05rem, 2vw, 1.28rem); }
  .about-profile__copy p:first-child { color: var(--color-text); }
  .about-now__list { border-top: 1px solid var(--color-border); }
  .about-now article { display: grid; grid-template-columns: 5rem minmax(0, 1fr) minmax(15rem, 0.8fr); gap: 2rem; padding-block: 1.7rem; border-bottom: 1px solid var(--color-border); }
  .about-now article > span { color: var(--color-accent-soft); font-size: 0.67rem; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; }
  .about-now h3 { margin: 0; font-family: var(--font-display); font-size: 1.65rem; font-weight: 500; }
  .about-now p { margin: 0; color: var(--color-muted); }
  .about-connect { display: flex; align-items: end; justify-content: space-between; gap: 3rem; margin-bottom: var(--section-space); padding: clamp(1.5rem, 4vw, 2.5rem); background: var(--gradient-accent); border-radius: var(--radius-card); color: var(--color-bg-deep); }
  .about-connect > div > span { font-size: 0.67rem; font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; }
  .about-connect h2 { max-width: 10ch; margin: 2rem 0 0; color: var(--color-bg-deep); font-size: clamp(2rem, 4vw, 3.2rem); }
  .about-connect nav { display: grid; gap: 0.5rem; }
  .about-connect a { color: var(--color-bg-deep); font-size: 0.78rem; font-weight: 800; text-decoration: none; }
  @media (max-width: 48rem) {
    .about-profile__grid { grid-template-columns: 1fr; }
    .about-profile__monogram { max-width: 24rem; }
    .about-now article { grid-template-columns: 4rem 1fr; }
    .about-now p { grid-column: 2; }
    .about-connect { align-items: start; flex-direction: column; }
  }
</style>
