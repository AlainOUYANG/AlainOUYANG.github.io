---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { profile } from '../../data/profile';
---

<BaseLayout title="关于" description="关于 Kzyo：智能营销、因果推断、Uplift Modeling 与 AI 应用。">
  <PageIntro eyebrow="About / 关于" title="你好，我是 Kzyo" description="一名互联网营销算法工程师，也是持续做公开实验的创造者。我关心怎样识别真正的增量，也关心 AI 怎样帮助人更好地学习、表达和工作。" />
  <section class="section-shell">
    <SectionHeading number="01" title="两条工作线，一套问题意识" />
    <div class="about-copy">
      <p>我的主线工作围绕智能营销、因果推断和 Uplift Modeling：从“谁可能响应”继续追问“谁会因为干预而改变”，再把答案放回实验和决策中验证。</p>
      <p>另一条线是 AI 应用与个人效率。我在探索 AI 播客、自媒体内容生成、知识管理和工作流自动化，也会用 AI 编程快速做工具和产品原型。</p>
      <p>计算机科学博士阶段的研究训练，让我习惯检查比较是否公平、指标是否回答了真正的问题，以及结论的边界在哪里。</p>
    </div>
  </section>
  <section class="section-shell">
    <SectionHeading number="02" title="现在关注" />
    <div class="about-list">
      <article><span>Work</span><h3>增量价值与营销决策</h3><p>异质性处理效应、实验评估和从模型到策略的连接。</p></article>
      <article><span>Build</span><h3>AI 原生工作流</h3><p>内容生产、知识管理、自动化与个人效率工具。</p></article>
      <article><span>Publish</span><h3>写作与播客</h3><p>围绕方法、实践和 AI 创作留下可复用的公开材料。</p></article>
    </div>
  </section>
  <section class="section-shell connect">
    <SectionHeading number="03" title="公开链接" />
    <nav aria-label="个人链接"><a href={profile.links.github}>GitHub ↗</a><a href={profile.links.scholar}>Google Scholar ↗</a><a href={profile.links.linkedin}>LinkedIn ↗</a><a href={profile.links.orcid}>ORCID ↗</a></nav>
  </section>
</BaseLayout>

<style>
  .about-copy { width: min(100%, var(--reading-width)); margin-inline: auto; }
  .about-copy p { color: var(--color-muted); font-size: clamp(1.02rem,1.7vw,1.18rem); }
  .about-copy p:first-child { color: var(--color-text); }
  .about-list { border-top: 1px solid var(--color-border); }
  .about-list article { display: grid; grid-template-columns: 7rem minmax(12rem,.7fr) minmax(16rem,1fr); gap: 2rem; padding-block: 1.35rem; border-bottom: 1px solid var(--color-border); }
  .about-list span { color: var(--color-subtle); font-family: var(--font-latin); font-size: .7rem; text-transform: uppercase; }
  .about-list h3, .about-list p { margin: 0; }
  .about-list h3 { font-size: 1.25rem; }
  .about-list p { color: var(--color-muted); font-size: .92rem; }
  .connect nav { display: flex; flex-wrap: wrap; gap: .7rem 1.5rem; padding-block: 1.25rem; border-block: 1px solid var(--color-border); }
  .connect a { font-family: var(--font-latin); font-size: .84rem; }
  @media (max-width: 44rem) { .about-list article { grid-template-columns: 1fr; gap: .4rem; } }
</style>
