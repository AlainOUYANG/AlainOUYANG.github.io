---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recent = posts.slice(0, 8);
---

<BaseLayout title="文章" description="Kzyo 关于因果推断、算法实践、AI 应用与阅读思考的文章。">
  <PageIntro eyebrow="Writing / 文章" title="写下可复用的方法与判断" description="围绕增量建模、实验评估、工程实践和 AI 应用，把零散经验整理成能够被检验和继续讨论的文字。" />
  <section class="section-shell">
    <SectionHeading number="01" title="最近整理" description="文章、研究笔记和未来的播客使用同一套索引；完整旧文仍可从历史归档访问。" />
    <div>{recent.map((post) => <ArticleCard eyebrow={post.data.category} title={post.data.title} description={post.data.description} href={post.data.permalink} meta={post.data.pubDate.toLocaleDateString('zh-CN')} />)}</div>
  </section>
  <section class="section-shell">
    <SectionHeading number="02" title="内容地图" />
    <nav class="content-map" aria-label="内容地图">
      <a href="/topics/"><span>Topic</span><b>方法与模型</b><small>因果推断、Uplift Modeling、实验评估。</small></a>
      <a href="/topics/"><span>Practice</span><b>工程与实践</b><small>从问题定义、建模到验证的可复用经验。</small></a>
      <a href="/lab/"><span>Build</span><b>AI 与创造</b><small>内容工作流、知识系统和个人效率工具。</small></a>
      <a href="/archive/"><span>Archive</span><b>历史归档</b><small>保留旧站文章原貌，不代表当前观点。</small></a>
    </nav>
  </section>
</BaseLayout>

<style>
  .content-map { border-top: 1px solid var(--color-border); }
  .content-map a { display: grid; grid-template-columns: 7rem minmax(12rem,.7fr) minmax(16rem,1fr); gap: 2rem; padding-block: 1.25rem; text-decoration: none; border-bottom: 1px solid var(--color-border); }
  .content-map span, .content-map small { color: var(--color-subtle); }
  .content-map span { font-family: var(--font-latin); font-size: .7rem; text-transform: uppercase; }
  .content-map b { font-weight: 400; }
  .content-map small { font-size: .84rem; }
  @media (max-width: 44rem) { .content-map a { grid-template-columns: 1fr; gap: .25rem; } }
</style>
